@model List<string>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <h2 class="text-center mb-4">📋 All Bookings</h2>

    <!-- 🔎 Search -->
    <form method="get" class="d-flex justify-content-center mb-4">
        <input type="text" name="search" class="form-control w-50 me-2"
               placeholder="Search user or location..." />
        <button class="btn btn-primary">Search</button>
    </form>

    <!-- 📊 Table -->
    <div class="card shadow p-3">
        <table class="table table-bordered table-hover text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>User</th>  
                    <th>Slot</th>
                    <th>Booking Time</th>
                    
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    var data = item.Split('|');

                    <tr>
                        <td>@data[0]</td>
                        <td>@data[1]</td>
                        <td>@data[2]</td>
                        
                       
                        
                        

                        <td>
                            <a href="/Admin/CancelBooking?user=@data[0]&slot=@data[1]"
                               class="btn btn-danger btn-sm">
                                Cancel
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 🔙 Back -->
    <div class="text-center mt-4">
        <a href="/Admin/Dashboard" class="btn btn-secondary">⬅ Back</a>
    </div>

</div>