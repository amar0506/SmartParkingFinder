<!DOCTYPE html>
<html lang="en">
<style>

    .glow-btn {
        transition: 0.3s;
        border-radius: 30px;
    }

        .glow-btn:hover {
            transform: scale(1.05);
            box-shadow: 0px 0px 12px rgba(13,110,253,0.6);
        }

</style>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - SmartParkingFinder</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>

<body>

    <!-- 🔥 NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom mb-3">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    🚗 Smart Parking Finder
                </a>

                <div class="navbar-nav">

                    <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="nav-link" asp-controller="Parking" asp-action="ShowParking">Find Parking</a>

                    @if (Context.Session.GetString("User") != null)
                    {
                        <span class="nav-link text-success fw-semibold">
                            👋 Welcome @Context.Session.GetString("User")
                        </span>

                        <a class="nav-link" asp-controller="Parking" asp-action="History">History</a>

                        <a class="nav-link fw-bold text-danger"
                           asp-controller="Account"
                           asp-action="Logout">
                            Logout
                        </a>
                    }
                    else
                    {
                        <a class="nav-link"
                           asp-controller="Account"
                           asp-action="Login">
                            Login
                        </a>
                    }

                </div>
            </div>
        </nav>
    </header>

    <!-- 🔥 BODY CONTENT -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- 🔥 FOOTER -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - SmartParkingFinder
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>