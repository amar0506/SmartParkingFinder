@model List<SmartParkingFinder.Models.BookingData>

@{
    ViewData["Title"] = "Parking Slots";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["msg"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            Swal.fire({
                title: "@TempData["type"]" === "success" ? "Success" : "Error",
                text: "@TempData["msg"]",
                icon: "@TempData["type"]",
                confirmButtonText: "OK"
            });

        });
    </script>
}

<script>
    function confirmAction(url, message) {
        event.preventDefault();

        Swal.fire({
            title: "Are you sure?",
            text: message,
            icon: "warning",
            showCancelButton: true,
            confirmButtonText: "Yes",
            cancelButtonText: "No"
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = url;
            }
        });
    }
</script>

<style>
    .slot-box {
        padding: 20px;
        border-radius: 12px;
        color: white;
        font-weight: bold;
        text-align: center;
        transition: 0.3s;
    }

        .slot-box:hover {
            transform: scale(1.08);
        }

    .available {
        background: linear-gradient(135deg, #00b09b, #96c93d);
    }

    .booked {
        background: linear-gradient(135deg, #ff416c, #ff4b2b);
    }

    .section-title {
        margin-top: 40px;
        font-weight: bold;
    }
</style>


<div class="container mt-4">

    <h2 class="text-center">🚗 Parking Slots</h2>
    <div class="text-center mt-4">

    </div>

    @if (Model == null || !Model.Any())
    {
        <h3 class="text-center text-danger mt-5">No Parking Data Found ❌</h3>
    }
    else
    {
        <!-- CITY -->
        <h4 class="section-title">🏢 City Mall Parking</h4>
        <div class="row g-3">
            @foreach (var slot in Model.Where(x => x.Location == "City Mall Parking"))
            {
                <div class="col-md-2">
                    <div class="slot-box @(slot.IsBooked ? "booked" : "available")">

                        <b>@slot.SlotName</b><br />

                        @if (slot.IsBooked)
                        {
                            <a href="@Url.Action("Cancel", "Parking", new { location = slot.Location, slot = slot.SlotName })"
                               onclick="confirmAction(this.href, 'Do you want to cancel booking?')"
                               class="text-white text-decoration-none">
                                Cancel
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Book", "Parking", new { location = slot.Location, slot = slot.SlotName })"
                               onclick="confirmAction(this.href, 'Do you want to book this slot?')"
                               class="text-white text-decoration-none">
                                Available
                            </a>
                        }

                    </div>
                </div>
            }
        </div>

        <!-- RAILWAY -->
        <h4 class="section-title">🚉 Railway Station Parking</h4>
        <div class="row g-3">
            @foreach (var slot in Model.Where(x => x.Location == "Railway Station Parking"))
            {
                <div class="col-md-2">
                    <div class="slot-box @(slot.IsBooked ? "booked" : "available")">

                        <b>@slot.SlotName</b><br />

                        @if (slot.IsBooked)
                        {
                            <a href="@Url.Action("Cancel", "Parking", new { location = slot.Location, slot = slot.SlotName })"
                               onclick="confirmAction(this.href, 'Do you want to cancel booking?')"
                               class="text-white text-decoration-none">
                                Cancel
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Book", "Parking", new { location = slot.Location, slot = slot.SlotName })"
                               onclick="confirmAction(this.href, 'Do you want to book this slot?')"
                               class="text-white text-decoration-none">
                                Available
                            </a>
                        }

                    </div>
                </div>
            }
        </div>

        <!-- BUS -->
        <h4 class="section-title">🚌 Bus Stand Parking</h4>
        <div class="row g-3">
            @foreach (var slot in Model.Where(x => x.Location == "Bus Stand Parking"))
            {
                <div class="col-md-2">
                    <div class="slot-box @(slot.IsBooked ? "booked" : "available")">

                        <b>@slot.SlotName</b><br />

                        @if (slot.IsBooked)
                        {
                            <a href="@Url.Action("Cancel", "Parking", new { location = slot.Location, slot = slot.SlotName })"
                               onclick="confirmAction(this.href, 'Do you want to cancel booking?')"
                               class="text-white text-decoration-none">
                                Cancel
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Book", "Parking", new { location = slot.Location, slot = slot.SlotName })"
                               onclick="confirmAction(this.href, 'Do you want to book this slot?')"
                               class="text-white text-decoration-none">
                                Available
                            </a>
                        }

                    </div>
                </div>
            }
        </div>
    }

    <div class="text-center mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-dark">
            ⬅ Back
        </a>
    </div>

</div>