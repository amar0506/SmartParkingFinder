@{
    ViewData["Title"] = "Find Parking";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    body {
        background: #f4f6f9;
    }

    .map-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .map-title {
        font-weight: 700;
        margin-bottom: 20px;
    }

    .map-frame {
        border-radius: 12px;
        overflow: hidden;
    }

    .btn-find {
        padding: 12px 30px;
        font-size: 18px;
        border-radius: 30px;
        transition: .3s;
    }

        .btn-find:hover {
            transform: scale(1.05);
        }

</style>


<div class="container mt-5">

    <div class="map-card text-center">

        <h2 class="map-title">📍 Find Parking Location</h2>

        <div class="map-frame">

            <iframe width="100%"
                    height="400"
                    style="border:0"
                    loading="lazy"
                    allowfullscreen
                    src="https://maps.google.com/maps?q=Satna&t=&z=13&ie=UTF8&iwloc=&output=embed">
            </iframe>

        </div>

        <br>

        <a asp-controller="Parking"
           asp-action="FindParking"
           class="btn btn-primary btn-find">

            🚗 Show Available Parking

        </a>

    </div>

</div>