@{
    ViewData["Title"] = "Book Slot";
}

<div class="container mt-5 text-center">

    <h2 class="mb-4">🚗 Book Parking Slot</h2>

    <div class="card p-4 mx-auto shadow-sm" style="max-width:500px;">

        <h4 class="text-primary">
            Selected Location:
            <span class="fw-bold">@ViewBag.Location</span>
        </h4>

        <h5 class="mt-3">
            Selected Slot:
            <span class="fw-bold">@ViewBag.Slot</span>
        </h5>

        <p class="text-muted mt-3">
            Click confirm to reserve your parking slot.
        </p>

        <form asp-controller="Parking" asp-action="BookingSuccess" method="post">

            <input type="hidden" name="location" value="@ViewBag.Location" />
            <input type="hidden" name="slot" value="@ViewBag.Slot" />

            <button type="submit" class="btn btn-success w-100 mt-3">
                ✅ Confirm Booking
            </button>

        </form>
        @if (TempData["Success"] != null)
        {
            <script>
                alert("@TempData["Success"]");
            </script>
        }

    </div>

</div>